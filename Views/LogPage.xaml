<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Petapeta.Views.LogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,12,24,24" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Button
            Grid.Row="0"
            HorizontalAlignment="Right"
            Command="{x:Bind ViewModel.OpenLogFolderCommand}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE838;" FontSize="14" />
                <TextBlock x:Uid="OpenLogFolderButtonLabel" />
            </StackPanel>
        </Button>

        <ListView
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.Logs}"
            SelectionMode="None"
            IsItemClickEnabled="False">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <TextBlock
                        Text="{x:Bind}"
                        FontFamily="Consolas"
                        TextWrapping="Wrap" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
